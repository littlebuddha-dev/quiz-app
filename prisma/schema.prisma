generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  clerkId             String         @unique
  email               String         @unique
  name                String?
  role                String         @default("CHILD")
  targetAge           Int?
  xp                  Int            @default(0)
  level               Int            @default(1)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  birthDate           DateTime?
  preferredCategories Json?
  bookmarks           Bookmark[]
  channel             Channel?
  comments            Comment[]
  histories           QuizHistory[]
  likes               QuizLike[]
  subscriptions       Subscription[]
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  nameJa       String?
  nameEn       String?
  nameZh       String?
  minAge       Int      @default(0)
  maxAge       Int?
  systemPrompt String?
  sortOrder    Int      @default(0)
  icon         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quizzes      Quiz[]
}

model Quiz {
  id           String            @id @default(cuid())
  categoryId   String
  targetAge    Int
  imageUrl     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  channelId    String?
  bookmarks    Bookmark[]
  comments     Comment[]
  channel      Channel?          @relation(fields: [channelId], references: [id])
  category     Category          @relation(fields: [categoryId], references: [id])
  histories    QuizHistory[]
  likes        QuizLike[]
  translations QuizTranslation[]
}

model QuizTranslation {
  id       String  @id @default(cuid())
  quizId   String
  locale   String
  title    String
  question String
  hint     String
  answer   String
  explanation String?
  type     String
  options  Json?
  imageUrl String?
  visualMode String?
  visualData String?
  quiz     Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, locale])
}

model QuizLike {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model QuizHistory {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  isCorrect Boolean
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model Channel {
  id          String         @id @default(cuid())
  userId      String         @unique
  name        String
  description String?
  avatarUrl   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]
  subscribers Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

model Comment {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiUsage {
  id              String   @id @default(cuid())
  modelId         String
  promptTokens    Int      @default(0)
  candidateTokens Int      @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  timestamp       DateTime @default(now())
  purpose         String?  // e.g., "QUIZ_GEN", "TOPIC_SUGGEST"
}
